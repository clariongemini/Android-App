{
  "version": "1.0",
  "sprint": "P",
  "tier": "P0",
  "owner": "AID",
  "description": "Minimum event set required before Product Reality can learn from users",
  "minimum_events": [
    {
      "name": "app_open",
      "constant": "APP_OPEN",
      "trigger": "Process cold start → foreground"
    },
    {
      "name": "session_start",
      "constant": "SESSION_START",
      "trigger": "App enters foreground"
    },
    {
      "name": "session_end",
      "constant": "SESSION_END",
      "trigger": "App enters background"
    },
    {
      "name": "core_action_started",
      "constant": "CORE_ACTION_STARTED",
      "trigger": "Primary user loop action begins (project-specific)"
    },
    {
      "name": "core_action_completed",
      "constant": "CORE_ACTION_COMPLETED",
      "trigger": "Primary user loop action succeeds"
    },
    {
      "name": "premium_view",
      "constant": "PREMIUM_VIEW",
      "trigger": "Paywall screen shown"
    },
    {
      "name": "premium_start",
      "constant": "PREMIUM_START",
      "trigger": "Subscribe tap on paywall"
    },
    {
      "name": "streak_day",
      "constant": "STREAK_DAY",
      "trigger": "Consecutive engagement day increments"
    },
    {
      "name": "daily_goal_completed",
      "constant": "DAILY_GOAL_COMPLETED",
      "trigger": "Daily goal met for profile"
    }
  ],
  "legacy_aliases": {
    "paywall_view": "premium_view",
    "paywall_subscribe_tap": "premium_start"
  },
  "code_ref": "app/src/main/java/{{PACKAGE_PATH}}/domain/model/AnalyticsEvent.kt",
  "pipeline_ref": "app/src/main/java/{{PACKAGE_PATH}}/repository/AnalyticsRepository.kt"
}
