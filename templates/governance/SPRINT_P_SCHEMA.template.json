{
  "version": "1.0",
  "description": "AID Sprint P live metrics schema — retention, session, completion, churn, conversion",
  "sprint": "P",
  "project": "{{APP_NAME}}",
  "target_testers": 10,
  "segments": ["default", "premium_trial", "power_user"],
  "metrics": {
    "retention": {
      "d1": {"type": "percent", "target": 40, "source": "analytics_events"},
      "d7": {"type": "percent", "target": 25, "source": "analytics_events"},
      "d30": {"type": "percent", "target": 15, "source": "analytics_events"}
    },
    "session": {
      "daily_active_rate": {"type": "percent", "target": 50},
      "avg_session_minutes": {"type": "float", "target_min": 3, "target_max": 15},
      "sessions_per_week": {"type": "float", "target": 4}
    },
    "completion": {
      "core_action_completion_rate": {"type": "percent", "target": 70},
      "daily_goal_completion": {"type": "percent", "target": 60}
    },
    "churn": {
      "d7_churn_rate": {"type": "percent", "max_acceptable": 75}
    },
    "conversion": {
      "trial_start_rate": {"type": "percent", "target": 10},
      "trial_to_paid": {"type": "percent", "target": 5}
    }
  },
  "live_data_status": "pre_launch",
  "activation_gate": "Sprint P device proof + minimum_events from catalog"
}
